{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "adore",
  "colors": {
    "primary": "#558184",
    "light": "#6fa3a6",
    "dark": "#456a6d"
  },
  "favicon": {
    "light": "/images/adore_logo.png",
    "dark": "favicon.png"
  },
  "navigation": {
    "groups": [
      {
        "group": "Overview",
        "pages": [
          "overview/introduction",
          "overview/premium",
          "overview/customization"
        ]
      },
      {
        "group": "Security Setup",
        "pages": [
          "security/overview",
          "security/antinuke",
          "security/antiraid",
          "security/fake-owner",
          "security/fake-permissions",
          "security/security-admins",
          "security/moderation",
          "security/hardban",
          "security/restrictcommand",
          "security/command-access",
          "security/filter"
        ]
      },
      {
        "group": "Server Configuration",
        "pages": [
          "configuration/setup",
          "configuration/prefix",
          "configuration/autorole",
          "configuration/logging",
          {
            "group": "Tickets",
            "icon": "tickets",
            "pages": [
              "configuration/tickets/overview",
              "configuration/tickets/setup",
              "configuration/tickets/commands",
              "configuration/tickets/forms",
              "configuration/tickets/messages",
              "configuration/tickets/staff"
            ]
          },
          {
            "group": "Roles",
            "icon": "users-gear",
            "pages": [
              "configuration/roles/vanity",
              "configuration/roles/booster",
              "configuration/roles/reaction",
              "configuration/roles/button"
            ]
          },
          {
            "group": "Messages",
            "icon": "message",
            "pages": [
              "configuration/messages/system",
              "configuration/messages/responder"
            ]
          },
          "configuration/poj",
          "configuration/stickymessage",
          "configuration/starboard",
          "configuration/voicemaster",
          "configuration/level-rewards",
          "configuration/bump-reminder",
          "configuration/autoreact",
          "configuration/channel-reactions",
          "configuration/imgonly",
          "configuration/command-aliases"
        ]
      },
      {
        "group": "Features",
        "pages": [
          "features/economy",
          "features/ai",
          "features/clownboard",
          "features/backup"
        ]
      },
      {
        "group": "Integrations",
        "pages": [
          "integrations/spotify",
          "integrations/lastfm"
        ]
      },
      {
        "group": "Resources",
        "pages": [
          "resources/syntax",
          {
            "group": "Scripting",
            "icon": "scroll",
            "pages": [
              "resources/scripting/embeds",
              "resources/scripting/variables"
            ]
          },
          "resources/permissions",
          "resources/events",
          "resources/voices",
          "resources/languages"
        ]
      },
      {
        "group": "Common Issues",
        "pages": [
          "common-issues/ios-dash",
          "common-issues/permissions",
          "common-issues/server-removal"
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/adore_logo.png",
    "dark": "/logo/logo.png"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "navbar": {
    "links": [
      {
        "label": "Support Server",
        "href": "https://discord.gg/q3e53k4qKQ"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Home",
      "href": "https://adore.rest"
    }
  },
  "seo": {
    "metatags": {
      "theme-color": "#080a0f",
      "og:site_name": "adore.rest"
    },
    "indexing": "all"
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/q3e53k4qKQ"
    }
  },
  "redirects": [
    {
      "source": "/premium",
      "destination": "https://adore.rest/premium",
      "permanent": true
    },
    {
      "source": "/commands",
      "destination": "https://adore.rest/commands"
    },
    {
      "source": "/status",
      "destination": "https://adore.rest/status"
    },
    {
      "source": "/invite",
      "destination": "https://adore.rest"
    },
    {
      "source": "/discord",
      "destination": "https://discord.gg/q3e53k4qKQ"
    }
  ],
  "icons": {
    "library": "fontawesome"
  },
  "background": {
    "decoration": "gradient"
  },
  "contextual": {
    "options": [
      "assistant"
    ],
    "display": "header"
  }
}
