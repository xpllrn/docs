DEFAULT EMBEDS 


# default panel message
{embed}
$v{author: pvt}
$v{title: adore}
$v{description: Click the button below to open a ticket. A private ticket channel will be created for you when you open one.}
$v{field: Max Open Tickets && 1 && inline}
$v{field: What To Include && Be clear about your issue, include screenshots or links when helpful, and wait for a staff response.}

# auto close
{embed}
$v{title: Ticket Closed Automatically}
$v{description: This ticket has been closed automatically after the author was inactive for too long. Use the controls below if it needs to be reopened or deleted.}
$v{field: Case && #{ticket.case} inline}
$v{field: Creator && {ticket.author.full}\n`({ticket.author.id})` inline}
$v{field: Claimer && {ticket.claimer.full}\n`({ticket.claimer.id})` inline}
$v{field: Channel && {ticket.channel.name}\n`({ticket.channel.id})` inline}
$v{field: Auto-Close After && {ticket.option.auto_close_after.human} inline}
$v{field: Closed && {ticket.closed_at} inline}
$v{field: Reason && {ticket.reason.closed}}

# auto delete
{embed}
$v{title: Ticket Scheduled For Deletion}
$v{description: This ticket is closed and will be deleted automatically if it stays closed.}
$v{field: Case && #{ticket.case} inline}
$v{field: Creator && {ticket.author.full}\n`({ticket.author.id})` inline}
$v{field: Deletes In && {ticket.auto_delete_after_close.human} inline}
$v{field: Deletes At && {ticket.auto_delete_at} inline}
$v{footer: Closed tickets are deleted automatically unless reopened first}

# claim
{embed}
$v{title: Ticket Claimed}
$v{description: This ticket is currently claimed. A team member has taken ownership of it.}
$v{field: Case && #{ticket.case} inline}
$v{field: Creator && {ticket.author.full}\n`({ticket.author.id})` inline}
$v{field: Claimer && {ticket.claimer.full}\n`({ticket.claimer.id})` inline}
$v{field: Channel && {ticket.channel.name}\n`({ticket.channel.id})` inline}
$v{field: Claimed && {ticket.claimed_at} inline}
$v{field: Reason && {ticket.reason.claimed}}
$v{footer: Claimed by {ticket.claimer.full}}

# close 
{embed}
$v{title: Ticket Closed}
$v{description: This ticket has been closed. Use the controls below if it needs to be reopened or deleted.}
$v{field: Case && #{ticket.case} inline}
$v{field: Creator && {ticket.author.full}\n`({ticket.author.id})` inline}
$v{field: Claimer && {ticket.claimer.full}\n`({ticket.claimer.id})` inline}
$v{field: Channel && {ticket.channel.name}\n`({ticket.channel.id})` inline}
$v{field: Closed && {ticket.closed_at} inline}
$v{field: Reason && {ticket.reason.closed}}
$v{footer: Closed by {ticket.closer.full}}

# Greetings
{embed}
$v{title: {ticket.opened_label} Ticket}
$v{description: Thanks for opening a ticket. A member of the team will be with you shortly. Use the controls below if you need to close or manage this ticket.}
$v{field: Case && #{ticket.case} inline}
$v{field: Creator && {ticket.author.full}\n`({ticket.author.id})` inline}
$v{field: Channel && {ticket.channel.name}\n`({ticket.channel.id})` inline}
$v{field: Panel && {ticket.panel.name} inline}
$v{field: Opened && {ticket.opened_at} inline}
$v{footer: Opened by {ticket.author.full}}
$v{message: Welcome {user.mention}. Someone from the team will be with you shortly.}

# Inactivity
{embed}
$v{title: Awaiting Your Response}
$v{description: We haven't heard from you in a bit. Send a message whenever you're ready to continue with this ticket.}
$v{field: Case && #{ticket.case} inline}
$v{field: Ticket Type && {ticket.opened_label} inline}
$v{field: Channel && {ticket.channel.name} inline}
$v{field: Last Author Message && {ticket.last_author_message_at}}
$v{message: {user.mention}}

# move
{embed}
$v{title: Ticket Moved}
$v{description: This ticket has been moved to a different panel option. Use the controls below to continue managing it.}
$v{field: Case && #{ticket.case} inline}
$v{field: Creator && {ticket.author.full}\n`({ticket.author.id})` inline}
$v{field: Claimer && {ticket.claimer.full}\n`({ticket.claimer.id})` inline}
$v{field: Panel && {ticket.panel.name} inline}
$v{field: Option && {ticket.opened_label} inline}
$v{field: Moved && {ticket.migrated_at} inline}
$v{field: Reason && {ticket.reason.migrated}}
$v{footer: Ticket moved}

# required roles
{embed}
$v{title: Missing Required Roles}
$v{description: You don't have the required roles to open **{ticket.option.label}** right now.}
$v{field: Required Roles && {ticket.option.required_roles.mentions}}
$v{field: Match && {ticket.option.required_roles.mode} inline}
$v{message: {user.mention}}

# reopen
{embed}
$v{title: Ticket Reopened}
$v{description: This ticket has been reopened and is ready for new messages.}
$v{field: Case && #{ticket.case} inline}
$v{field: Creator && {ticket.author.full}\n`({ticket.author.id})` inline}
$v{field: Claimer && {ticket.claimer.full}\n`({ticket.claimer.id})` inline}
$v{field: Channel && {ticket.channel.name}\n`({ticket.channel.id})` inline}
$v{field: Reopened && {ticket.reopened_at} inline}
$v{field: Last Closed && {ticket.closed_at} inline}
$v{field: Reason && {ticket.reason.reopened}}
$v{footer: Reopened by {ticket.reopener.full}}

